## ai-watchdog memory module config
## Copy this to .env and fill in your values
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://your-litellm-endpoint.example.com
SUMMARY_MODEL=anthropic/claude-opus-4.6

## Hermes Notification Channels (set the ones you use, leave others empty)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
DINGTALK_WEBHOOK_URL=
DINGTALK_SECRET=
FEISHU_WEBHOOK_URL=
FEISHU_SECRET=
GENERIC_WEBHOOK_URL=

## Hermes MoA (comma-separated model names for parallel LLM analysis)
MOA_MODELS=
